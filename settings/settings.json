{
  "respectGitignore": true,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(npm publish*)",
      "Bash(kill *)",
      "Bash(killall *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/delete-guard.sh",
            "timeout": 5,
            "statusMessage": "Safety check"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git-safety.sh",
            "timeout": 5,
            "statusMessage": "Git safety"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/secret-scan.sh",
            "timeout": 10,
            "statusMessage": "Secret scan"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/read-tracker.sh",
            "timeout": 3,
            "statusMessage": "Read tracker"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/scope-guard.sh",
            "timeout": 5,
            "statusMessage": "Scope guard"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/spec-compliance.sh",
            "timeout": 5,
            "statusMessage": "Spec compliance"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/phase-gate.sh",
            "timeout": 5,
            "statusMessage": "Phase gate"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/loop-detect.sh",
            "timeout": 3,
            "statusMessage": "Loop check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/accumulate.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/error-tracker.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before compaction: 1) Update sessions/scratchpad.md with current task, mode, working state, key decisions, dead ends, and files being edited so context survives. 2) Scan recent exchanges for unlogged evolve signals and append to sessions/evolve_signals.md.",
            "once": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context compacted. Re-read sessions/scratchpad.md and sessions/state.json to restore working state.'",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Session ending. Auto-persist (mandatory, never skip):\n1) Scan the ENTIRE conversation for unlogged evolve signals (accept/rework/reject/love/repeat/skip) and append to sessions/evolve_signals.md\n2) Update memory/L1_essential.md if any decisions, feedback, or project state changed\n3) Update sessions/state.json with current phase and recovery instructions\n4) If any memory files need updating (feedback corrections, project state changes), write them now\nReport: '[N] signals logged, L1 [updated/unchanged], state.json [updated/unchanged]'"
          }
        ]
      }
    ]
  }
}