{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(rm *) || Bash(git push *) || Bash(git reset *) || Bash(git clean *) || Bash(kubectl delete *) || Bash(docker system prune *)",
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"gOS careful: destructive command detected\"}}'",
            "timeout": 5,
            "statusMessage": "gOS careful check"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "if": "Edit(.env*) || Edit(*.key) || Edit(*.pem) || Edit(*.p12) || Edit(*.pfx) || Edit(credentials.json) || Edit(secrets.yaml) || Edit(secrets.yml) || Write(.env*) || Write(*.key) || Write(*.pem) || Write(*.p12) || Write(*.pfx) || Write(credentials.json) || Write(secrets.yaml) || Write(secrets.yml)",
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"gOS protect: sensitive file blocked\"}}'",
            "timeout": 5,
            "statusMessage": "gOS protect-files check"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/freeze-guard.sh\"",
            "timeout": 5,
            "statusMessage": "gOS freeze check"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/plan-gate.sh\"",
            "timeout": 5,
            "statusMessage": "gOS plan gate"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/secret-scan.sh\"",
            "timeout": 10,
            "statusMessage": "gOS secret scan"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/post-commit-detect.sh\"",
            "timeout": 10,
            "statusMessage": "gOS spec drift check"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/spec-drift.sh\"",
            "timeout": 5,
            "statusMessage": "gOS spec sync reminder"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/file-changed-drift.sh\"",
            "timeout": 5,
            "statusMessage": "gOS file change monitor"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/permission-denied-handler.sh\"",
            "timeout": 5,
            "statusMessage": "gOS permission denied handler"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/scratchpad-checkpoint.sh\"",
            "timeout": 10,
            "statusMessage": "gOS session checkpoint"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "firecrawl@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "mobile-design-engine@local-plugins": true,
    "investment-banking@financial-services-plugins": true,
    "financial-analysis@financial-services-plugins": true,
    "equity-research@financial-services-plugins": true,
    "private-equity@financial-services-plugins": true,
    "wealth-management@financial-services-plugins": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "claude-mem@thedotmack": true,
    "skill-creator@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true
  },
  "extraKnownMarketplaces": {
    "local-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/REPLACE_WITH_YOUR_USERNAME/claude-plugins"
      }
    },
    "financial-services-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/financial-services-plugins"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    }
  }
}
