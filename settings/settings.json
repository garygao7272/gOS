{
  "respectGitignore": true,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(npm publish*)",
      "Bash(kill *)",
      "Bash(killall *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/plan-gate-prompt.sh",
            "timeout": 5,
            "statusMessage": "Plan gate (open/approve/bypass)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/plan-gate.sh",
            "timeout": 5,
            "statusMessage": "Plan gate (git)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/delete-guard.sh",
            "timeout": 5,
            "statusMessage": "Safety check"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git-safety.sh",
            "timeout": 5,
            "statusMessage": "Git safety"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/security-gate.sh",
            "timeout": 10,
            "statusMessage": "Security gate (secrets + dangerous cmds)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/health-gate.sh",
            "timeout": 120,
            "statusMessage": "Health gate"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/gos-drift-gate.sh",
            "timeout": 10,
            "statusMessage": "gOS drift gate"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/read-tracker.sh",
            "timeout": 3,
            "statusMessage": "Read tracker"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/plan-gate.sh",
            "timeout": 5,
            "statusMessage": "Plan gate"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/scope-guard.sh",
            "timeout": 5,
            "statusMessage": "Scope guard"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/spec-compliance.sh",
            "timeout": 5,
            "statusMessage": "Spec compliance"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/phase-gate.sh",
            "timeout": 5,
            "statusMessage": "Phase gate"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/loop-detect.sh",
            "timeout": 3,
            "statusMessage": "Loop check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/accumulate.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-commit-detect.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/error-tracker.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before compaction: 1) Update sessions/scratchpad.md with current task, mode, working state, key decisions, dead ends, and files being edited so context survives. 2) Scan recent exchanges for unlogged evolve signals and append to sessions/evolve_signals.md.",
            "once": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context compacted. Re-read sessions/scratchpad.md and sessions/state.json to restore working state.'",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/session-stop-gate.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh",
            "timeout": 3,
            "statusMessage": "Notify"
          }
        ]
      }
    ]
  }
}