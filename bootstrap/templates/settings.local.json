  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are a Spec Compliance Gate. Verify that implementation matches the spec.\n\n1. Check which files were just edited (look at recent tool use in the transcript)\n2. Map edited files to specs:\n   - apps/web-prototype/ → specs/Arx_4-1-1-* (mobile screen specs)\n   - apps/mobile/ → specs/Arx_5-* (engineering specs)\n   - specs/ changes → check cascade rule (changes flow downward only)\n3. Read the relevant spec section\n4. Compare: Do component names, data shapes, interactions, and design tokens match?\n5. If mismatch: {\"ok\": false, \"reason\": \"Spec says X but implementation has Y\"}\n6. If aligned or no spec applies: {\"ok\": true}\n\nOnly flag clear mismatches — not style preferences.",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-save.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/sessions/last-session.md\" ]; then cat \"$CLAUDE_PROJECT_DIR/sessions/last-session.md\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "STATE=\"$CLAUDE_PROJECT_DIR/sessions/state.json\"; if [ -f \"$STATE\" ]; then CMD=$(python3 -c \"import json; d=json.load(open('$STATE')); print(d.get('current_command',''))\" 2>/dev/null); if [ -n \"$CMD\" ] && [ \"$CMD\" != \"None\" ]; then echo \"RECOVERY: Previous session was running '$CMD'. Recovery: $(python3 -c \"import json; print(json.load(open('$STATE')).get('recovery_instructions','no details'))\" 2>/dev/null)\"; fi; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-gate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/plan-gate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/freeze-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prototype-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/middleware-chain.sh pre",
            "timeout": 10,
            "statusMessage": "Middleware pre-chain..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scratchpad-checkpoint.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format.sh",
            "timeout": 15,
            "statusMessage": "Formatting..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/spec-drift.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-commit-detect.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/test-fix-loop.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context-recovery.sh",
            "timeout": 5
          },
          {
            "type": "command",
