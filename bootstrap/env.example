# God System — Required Environment Variables
# Copy this file to ~/.env.local and fill in your actual values.
# These are referenced by .mcp.json and various tools.

# ─── GitHub ───────────────────────────────────────────────
# Used by: GitHub MCP server
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── Discord ──────────────────────────────────────────────
# Used by: Discord MCP server (community monitoring)
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# ─── Telegram ─────────────────────────────────────────────
# Used by: Telegram MCP server (trading group monitoring)
# Get from: https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash

# ─── Notte ────────────────────────────────────────────────
# Used by: Notte MCP server (anti-detection browser)
# Get from: https://notte.cc
NOTTE_API_KEY=your_notte_api_key

# ─── Anthropic (optional) ────────────────────────────────
# Used by: Claude API calls (if building with Claude SDK)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Slack (OAuth) ────────────────────────────────────────
# Authenticated via OAuth in Claude Desktop — run /mcp to set up.
# No env var needed.

# ─── Sentry (OAuth) ──────────────────────────────────────
# Authenticated via OAuth in Claude Desktop — run /mcp to set up.
# No env var needed.

# ─── Hyperliquid ──────────────────────────────────────────
# Public API — no authentication needed.

# ─── Spec-RAG ─────────────────────────────────────────────
# Local only — no authentication needed.
# Vector DB rebuilds automatically via: /schedule run reindex-specs
