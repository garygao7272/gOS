{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-soul.sh\"",
            "timeout": 10,
            "statusMessage": "gOS soul injection"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/init-session.sh\"",
            "timeout": 5,
            "statusMessage": "gOS session init"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | { read -r c; if echo \"$c\" | grep -qE '(node_modules|dist/|/build/|\\.next|__pycache__|\\.firecrawl)'; then echo '{}'; elif echo \"$c\" | grep -iqE '(rm\\s+(-[a-zA-Z]*f|-[a-zA-Z]*r|--force|--recursive)\\b|DROP\\s+TABLE|git\\s+push\\s+(--force|-f)\\b|git\\s+reset\\s+--hard|kubectl\\s+delete|docker\\s+system\\s+prune)'; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"gOS careful: destructive command detected\"}}'; else echo '{}'; fi; }",
            "timeout": 5,
            "statusMessage": "gOS careful check"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/secret-scan.sh\"",
            "timeout": 5,
            "statusMessage": "gOS secret scan"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-files.sh\"",
            "timeout": 5,
            "statusMessage": "gOS protect files"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if [ -f ~/.claude/freeze-scope.txt ]; then scope=$(cat ~/.claude/freeze-scope.txt); case \"$f\" in \"$scope\"*) echo '{}';; *) printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"gOS freeze: edit blocked — file outside frozen scope\"}}';; esac; else echo '{}'; fi; }",
            "timeout": 5,
            "statusMessage": "gOS freeze check"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/intent-gate-check.sh\"",
            "timeout": 5,
            "statusMessage": "gOS intent gate"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-gate.sh\"",
            "timeout": 5,
            "statusMessage": "gOS plan gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/artifact-frontmatter-check.sh\"",
            "timeout": 5,
            "statusMessage": "gOS artifact check"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/state-tracker.sh\"",
            "timeout": 5,
            "statusMessage": "gOS state tracker"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-commit-detect.sh\"",
            "timeout": 5,
            "statusMessage": "gOS spec drift detect"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/context-monitor.sh\"",
            "timeout": 5,
            "statusMessage": "gOS context monitor"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/scratchpad-checkpoint.sh\"",
            "timeout": 5,
            "statusMessage": "gOS scratchpad save"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/signal-capture.sh\"",
            "timeout": 10,
            "statusMessage": "gOS signal capture"
          }
        ]
      }
    ]
  }
}
