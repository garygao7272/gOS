{
  "respectGitignore": true,
  "enableAllProjectMcpServers": true,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(npm publish*)",
      "Bash(kill *)",
      "Bash(killall *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/precompact-save.sh",
            "timeout": 10
          },
          {
            "type": "prompt",
            "prompt": "Post-checkpoint sweep: 1) Scan recent conversation for unlogged evolve signals and append to sessions/evolve_signals.md. 2) Update sessions/scratchpad.md with current task state, decisions, dead ends, files being edited. 3) Refresh memory/L1_essential.md 'Current Focus'. The command hook (precompact-save.sh) has already written a checkpoint marker and updated Context — this prompt fills in the qualitative detail.",
            "once": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gos@gos-marketplace": false
  }
}