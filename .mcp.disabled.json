{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      },
      "disabled": true
    },
    "telegram": {
      "command": "npx",
      "args": [
        "-y",
        "@overpod/mcp-telegram"
      ],
      "env": {
        "TELEGRAM_API_ID": "${TELEGRAM_API_ID}",
        "TELEGRAM_API_HASH": "${TELEGRAM_API_HASH}"
      },
      "disabled": true
    },
    "notte": {
      "command": "/Users/garyg/Documents/Claude Working Folder/toolkit/notte-env/bin/python",
      "args": [
        "-m",
        "notte_mcp.server"
      ],
      "env": {
        "NOTTE_API_KEY": "${NOTTE_API_KEY}"
      },
      "disabled": true
    },
    "stitch": {
      "command": "node",
      "args": [
        "/Users/garyg/Documents/Claude Working Folder/toolkit/stitch-proxy.mjs"
      ],
      "env": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      },
      "disabled": true
    }
  }
}
